<Window x:Class="ClickRun.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClickRun.UI"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        mc:Ignorable="d"
        Title="ClickRun"
        Height="520" Width="400"
        MinHeight="480" MinWidth="360"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        Topmost="{Binding AlwaysOnTop}">

    <Window.Resources>
        <!-- 标签样式 -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{DynamicResource BodyFont}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource ForegroundSecondaryBrush}" />
        </Style>

        <!-- 开始/停止按钮样式 -->
        <Style x:Key="ToggleButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="{DynamicResource BodyFont}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="32,12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource StopBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 细线分隔样式 -->
        <Style x:Key="ThinSeparator" TargetType="Border">
            <Setter Property="Height" Value="1" />
            <Setter Property="Background" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Margin" Value="0,10" />
        </Style>

        <!-- 图标按钮样式 -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- ==================== 主界面 ==================== -->
        <Grid x:Name="MainPanel" Margin="20"
              Visibility="{Binding IsMainViewVisible}">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- 标题区 -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="ClickRun" Style="{DynamicResource H1Style}" Margin="0" />
                    <TextBlock Text="鼠标连点器" Style="{DynamicResource CaptionStyle}" />
                </StackPanel>
                <Button Grid.Column="1"
                        Style="{DynamicResource IconButtonStyle}"
                        Command="{Binding ShowSettingsCommand}"
                        VerticalAlignment="Top" Margin="0,4,0,0">
                    <TextBlock Text="⚙" FontSize="18" Foreground="{DynamicResource ForegroundSecondaryBrush}" />
                </Button>
            </Grid>

            <!-- 热键+模式行 -->
            <Grid Grid.Row="1" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="热键" Style="{DynamicResource CaptionStyle}" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <Border Background="{DynamicResource InkBrush}" Padding="10,4" CornerRadius="3" Margin="0,0,6,0">
                        <TextBlock Text="{Binding HotKeyName}" FontFamily="{DynamicResource MonoFont}" FontSize="14" Foreground="White" VerticalAlignment="Center" />
                    </Border>
                    <Button Content="修改" Style="{DynamicResource SecondaryButton}" Command="{Binding ChangeHotKeyCommand}" Padding="10,4" FontSize="12" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="模式" Style="{DynamicResource CaptionStyle}" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <RadioButton Content="单击" Style="{DynamicResource SegmentStyle}" GroupName="Mode" Margin="0,0,3,0">
                        <RadioButton.IsChecked>
                            <Binding Path="Config.Mode" Mode="TwoWay" Converter="{x:Static local:ClickModeConverter.Single}" />
                        </RadioButton.IsChecked>
                    </RadioButton>
                    <RadioButton Content="双击" Style="{DynamicResource SegmentStyle}" GroupName="Mode" Margin="0,0,3,0">
                        <RadioButton.IsChecked>
                            <Binding Path="Config.Mode" Mode="TwoWay" Converter="{x:Static local:ClickModeConverter.Double}" />
                        </RadioButton.IsChecked>
                    </RadioButton>
                    <RadioButton Content="三击" Style="{DynamicResource SegmentStyle}" GroupName="Mode">
                        <RadioButton.IsChecked>
                            <Binding Path="Config.Mode" Mode="TwoWay" Converter="{x:Static local:ClickModeConverter.Triple}" />
                        </RadioButton.IsChecked>
                    </RadioButton>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2" Style="{DynamicResource ThinSeparator}" />

            <!-- 核心设置区 -->
            <StackPanel Grid.Row="3" Margin="0,2,0,2">
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="按键" Style="{DynamicResource CaptionStyle}" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <RadioButton Content="左键" Style="{DynamicResource SegmentStyle}" GroupName="Button" Margin="0,0,4,0">
                            <RadioButton.IsChecked><Binding Path="Config.Button" Mode="TwoWay" Converter="{x:Static local:EnumConverter.Left}" /></RadioButton.IsChecked>
                        </RadioButton>
                        <RadioButton Content="右键" Style="{DynamicResource SegmentStyle}" GroupName="Button" Margin="0,0,4,0">
                            <RadioButton.IsChecked><Binding Path="Config.Button" Mode="TwoWay" Converter="{x:Static local:EnumConverter.Right}" /></RadioButton.IsChecked>
                        </RadioButton>
                        <RadioButton Content="中键" Style="{DynamicResource SegmentStyle}" GroupName="Button">
                            <RadioButton.IsChecked><Binding Path="Config.Button" Mode="TwoWay" Converter="{x:Static local:EnumConverter.Middle}" /></RadioButton.IsChecked>
                        </RadioButton>
                    </StackPanel>
                </Grid>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="间隔" Style="{DynamicResource CaptionStyle}" VerticalAlignment="Center" />
                    <Slider Grid.Column="1" Style="{DynamicResource SliderStyle}" Minimum="1" Maximum="10000" TickFrequency="50" Value="{Binding Config.Interval, Mode=TwoWay}" Margin="0,0,8,0" />
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Config.Interval}" Style="{DynamicResource DataStyle}" />
                        <TextBlock Text=" ms" Style="{DynamicResource CaptionStyle}" />
                    </StackPanel>
                </Grid>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="随机" Style="{DynamicResource CaptionStyle}" VerticalAlignment="Center" />
                    <Slider Grid.Column="1" Style="{DynamicResource SliderStyle}" Minimum="0" Maximum="50" TickFrequency="5" Value="{Binding Config.RandomDelay, Mode=TwoWay}" Margin="0,0,8,0" />
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="±" Style="{DynamicResource CaptionStyle}" />
                        <TextBlock Text="{Binding Config.RandomDelay}" Style="{DynamicResource DataStyle}" />
                        <TextBlock Text="%" Style="{DynamicResource CaptionStyle}" />
                    </StackPanel>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="次数" Style="{DynamicResource CaptionStyle}" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <RadioButton Content="无限" Style="{DynamicResource SegmentStyle}" IsChecked="{Binding IsUnlimited}" GroupName="Limit" Margin="0,0,4,0" />
                        <RadioButton Content="指定" Style="{DynamicResource SegmentStyle}" IsChecked="{Binding IsLimited}" GroupName="Limit" Margin="0,0,6,0" />
                        <TextBox Style="{DynamicResource TextBoxStyle}" Width="70" Text="{Binding Config.ClickLimit, Mode=TwoWay}" IsEnabled="{Binding IsLimited}" Padding="6,4" />
                        <TextBlock Text=" 次" VerticalAlignment="Center" Style="{DynamicResource CaptionStyle}" />
                    </StackPanel>
                </Grid>
            </StackPanel>

            <Border Grid.Row="4" Style="{DynamicResource ThinSeparator}" />

            <!-- 开始按钮 -->
            <Button Grid.Row="5" Content="{Binding ButtonText}" Style="{StaticResource ToggleButtonStyle}" Command="{Binding ToggleCommand}" Margin="0,4,0,4" />

            <Border Grid.Row="6" Style="{DynamicResource ThinSeparator}" />

            <!-- 统计区 -->
            <Grid Grid.Row="7" Margin="0,2,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,4,6">
                    <TextBlock Text="已点击" Style="{DynamicResource CaptionStyle}" />
                    <TextBlock Text="{Binding SessionClicksText}" Style="{DynamicResource DataLargeStyle}" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="4,0,0,6">
                    <TextBlock Text="运行时长" Style="{DynamicResource CaptionStyle}" />
                    <TextBlock Text="{Binding DurationText}" Style="{DynamicResource DataLargeStyle}" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,4,0">
                    <TextBlock Text="点击速度" Style="{DynamicResource CaptionStyle}" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding CpsText}" Style="{DynamicResource DataStyle}" />
                        <TextBlock Text=" 次/秒" Style="{DynamicResource CaptionStyle}" VerticalAlignment="Bottom" Margin="4,0,0,2" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="4,0,0,0">
                    <TextBlock Text="总点击次数" Style="{DynamicResource CaptionStyle}" />
                    <TextBlock Text="{Binding TotalClicksText}" Style="{DynamicResource DataStyle}" />
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ==================== 设置页面 ==================== -->
        <Grid x:Name="SettingsPanel" Margin="20"
              Visibility="{Binding IsSettingsViewVisibleAsVisibility}">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- 标题区 -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Style="{DynamicResource IconButtonStyle}" Command="{Binding HideSettingsCommand}" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock Text="←" FontSize="18" Foreground="{DynamicResource ForegroundSecondaryBrush}" />
                </Button>
                <TextBlock Grid.Column="1" Text="设置" Style="{DynamicResource H1Style}" VerticalAlignment="Center" Margin="0" />
                <Border Grid.Column="2" Width="30" />
            </Grid>

            <Border Grid.Row="1" Style="{DynamicResource ThinSeparator}" />

            <!-- 通用设置 -->
            <StackPanel Grid.Row="2" Margin="0,8,0,8">
                <TextBlock Text="通用" Style="{DynamicResource CaptionStyle}" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="0,0,0,12" />
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="开机自启动" Style="{DynamicResource BodyStyle}" FontWeight="SemiBold" />
                        <TextBlock Text="Windows启动时自动运行ClickRun" Style="{DynamicResource CaptionStyle}" />
                    </StackPanel>
                    <CheckBox Grid.Column="1" Style="{DynamicResource ToggleStyle}" IsChecked="{Binding StartWithWindows}" VerticalAlignment="Center" />
                </Grid>
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="最小化到托盘" Style="{DynamicResource BodyStyle}" FontWeight="SemiBold" />
                        <TextBlock Text="关闭窗口时最小化到系统托盘" Style="{DynamicResource CaptionStyle}" />
                    </StackPanel>
                    <CheckBox Grid.Column="1" Style="{DynamicResource ToggleStyle}" IsChecked="{Binding Config.MinimizeToTray}" VerticalAlignment="Center" />
                </Grid>
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="窗口置顶" Style="{DynamicResource BodyStyle}" FontWeight="SemiBold" />
                        <TextBlock Text="窗口始终显示在最上层" Style="{DynamicResource CaptionStyle}" />
                    </StackPanel>
                    <CheckBox Grid.Column="1" Style="{DynamicResource ToggleStyle}" IsChecked="{Binding AlwaysOnTop}" VerticalAlignment="Center" />
                </Grid>
            </StackPanel>

            <Border Grid.Row="3" Style="{DynamicResource ThinSeparator}" />

            <!-- 提示设置 -->
            <StackPanel Grid.Row="4" Margin="0,8,0,8">
                <TextBlock Text="提示" Style="{DynamicResource CaptionStyle}" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="0,0,0,12" />
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="播放音效" Style="{DynamicResource BodyStyle}" FontWeight="SemiBold" />
                        <TextBlock Text="开始/停止时播放提示音" Style="{DynamicResource CaptionStyle}" />
                    </StackPanel>
                    <CheckBox Grid.Column="1" Style="{DynamicResource ToggleStyle}" IsChecked="{Binding Config.PlaySound}" VerticalAlignment="Center" />
                </Grid>

                <TextBlock Text="关于" Style="{DynamicResource CaptionStyle}" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="0,8,0,12" />
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock Text="版本" Style="{DynamicResource BodyStyle}" />
                    <TextBlock Grid.Column="1" Text="v2.0" Style="{DynamicResource DataStyle}" />
                </Grid>
                <Button Content="项目主页 →" Style="{DynamicResource SecondaryButton}" Command="{Binding OpenProjectUrlCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,0,0,6" />
                <Button Content="GitHub →" Style="{DynamicResource SecondaryButton}" Command="{Binding OpenGitHubUrlCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" />
            </StackPanel>
        </Grid>

        <!-- 系统托盘图标 -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="ClickRun - 鼠标连点器"
                        DoubleClickCommand="{Binding ToggleCommand}"
                        Visibility="Collapsed">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="显示主窗口" Click="ShowMenuItem_Click" />
                    <Separator />
                    <MenuItem Header="退出" Click="ExitMenuItem_Click" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Grid>
</Window>
